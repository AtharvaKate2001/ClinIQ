# ─────────────────────────────────────────────────────────────────────────────
# ClinIQ — Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=ClinIQ
APP_VERSION=1.0.0
DEBUG=false

# ── LLM Provider (choose one) ────────────────────────────────────────────────
# Options: groq | ollama | openai | google
LLM_PROVIDER=groq

# ── Groq (FREE — recommended) ────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com
GROQ_API_KEY= Your_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama3-8b-8192

# ── Ollama (100% FREE, local) ─────────────────────────────────────────────────
# Install Ollama: https://ollama.com  then run: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── OpenAI (optional, paid) ───────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini (optional, free tier) ───────────────────────────────────────
# Get key at: https://aistudio.google.com
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash

# ── Embeddings (runs locally, free) ──────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB (local, free) ────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=cliniq_knowledge

# ── Langfuse Observability (optional, free tier) ─────────────────────────────
# Sign up free at: https://cloud.langfuse.com
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Domain (healthcare | finance) ────────────────────────────────────────────
# Change to "finance" to adapt this system for financial document analysis
DOMAIN=healthcare

# ── RAG Settings ─────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
